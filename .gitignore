# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.vite/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
logs/

# Env (never commit secrets)
.env
.env.local
.env.*.local

# Google OAuth client credentials downloaded from the Cloud Console — the
# JSON file is named `client_secret_<client-id>.apps.googleusercontent.com.json`
# and contains a client secret we don't need (ID-token verification uses
# public JWKs). Even though we don't USE it, the file lying around the
# repo is a leak risk — gitignore it everywhere.
client_secret_*.json
client_secret_*.apps.googleusercontent.com.json

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Test output
coverage/
.nyc_output/

# Misc
*.tsbuildinfo
.cache/
