# Frontend environment variables (only VITE_-prefixed vars reach the browser bundle).
# See docs/deployment/environment-variables.md for the full reference.

# ─── API base URL ───
# Leave UNSET (or empty) for same-origin requests (recommended).
# Same-origin means the Axios baseURL becomes `/api/v1` and requests go to
# whatever host the page is served from — Vite's dev proxy tunnels them
# to the backend (http://localhost:3000 by default).
#
# Override the proxy target via VITE_BACKEND_PROXY (consumed by vite.config.ts):
#   VITE_BACKEND_PROXY=http://192.168.1.10:3000 pnpm dev
#
# Only set VITE_API_URL when the backend is on a different host AND you're
# bypassing the Vite proxy. Most setups don't need this.
# VITE_API_URL=http://localhost:3000

# ─── MSW (Mock Service Worker) toggle ───
# Default: unset → MSW does NOT start; frontend talks to the real backend
# via the Vite proxy. Set to "true" to switch to MSW mock mode (no backend
# needed — useful for frontend-only iteration).
# VITE_USE_MSW=true

# Display name + public origin (used for share-link copy-to-clipboard UI)
VITE_APP_NAME=Perxli
VITE_PUBLIC_BASE_URL=http://localhost:5173

# Optional — used for Sentry / analytics scoping
VITE_ENV=development
