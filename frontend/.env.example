# Frontend environment variables (only VITE_-prefixed vars reach the browser bundle).
# See docs/deployment/environment-variables.md for the full reference.

# ─── API base URL ───
# Leave UNSET (or empty) for same-origin requests (recommended for dev).
# Same-origin means the Axios baseURL becomes `/api/v1` and requests go to
# whatever host the page is served from. This is what:
#   - MSW needs in dev (service workers only intercept same-origin)
#   - NGINX needs in prod (it reverse-proxies /api/* to the backend)
#
# Only set VITE_API_URL when the backend is on a different host:port AND
# you're not using a Vite proxy or NGINX. Most setups don't need this.
# VITE_API_URL=http://localhost:3000

# Display name + public origin (used for share-link copy-to-clipboard UI)
VITE_APP_NAME=KaziPay
VITE_PUBLIC_BASE_URL=http://localhost:5173

# Optional — used for Sentry / analytics scoping
VITE_ENV=development
