# Backend env — copy to backend/.env (gitignored).

# ─── App ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────────
# Matches docker-compose.yml's `db` service defaults. The host port is
# 5433 (not 5432) to dodge conflicts with locally-installed PostgreSQL
# services. Inside the container Postgres still listens on 5432.
# Change if you override root .env DB_NAME/DB_USER/DB_PASSWORD.
DATABASE_URL=postgresql://perxli:changeme_local@localhost:5433/perxli?schema=public

# ─── Auth (JWT + sessions) ───────────────────────────────────────────
# RS256 keys are auto-generated on first boot into backend/.keys/ if missing.
# To use specific keys (production), set these to PEM strings (base64 if you
# need to put them in a single env var).
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=

ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7

# ─── CORS ────────────────────────────────────────────────────────────
# Frontend origin allowed to make cross-origin requests with credentials.
# Vite dev server: http://localhost:5173. Add others (LAN IP for phone
# testing) as comma-separated values.
CORS_ORIGINS=http://localhost:5173

# ─── Rate limits ─────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
