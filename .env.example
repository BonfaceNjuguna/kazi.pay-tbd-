# Root .env for Docker Compose substitution.
# Copy to `.env` (gitignored) and adjust values for your local setup.
#
# Per AGENTS.md security rules: NEVER commit real secrets. Production
# secrets come from a secrets manager, not this file.

# ─── Database (consumed by docker-compose.yml and backend/) ─────────────
DB_NAME=perxli
DB_USER=perxli
DB_PASSWORD=changeme_local

# The backend reads DATABASE_URL via backend/.env — it's derived from the
# above but lives where Prisma can see it.
