# Example .env for /opt/perxli/{stage,prod}/.env on the Contabo VPS.
#
# Copy to .env on the VPS, fill in real values, then:
#   chmod 600 /opt/perxli/{stage,prod}/.env
#   chown deploy:deploy /opt/perxli/{stage,prod}/.env
#
# NEVER commit a real .env to git. The contabo-setup runbook walks
# through key generation per environment + the secrets matrix.

# ─── Image tag ───────────────────────────────────────────────────────
# Defaults to `latest-{env}` so a fresh `docker compose pull` grabs the
# newest pushed image. Pin to `sha-<commit>` to roll back; see ADR-006
# §Rollback for the procedure.
# IMAGE_TAG=latest-stage

# ─── Database ────────────────────────────────────────────────────────
DB_NAME=perxli
DB_USER=perxli
DB_PASSWORD=<generate-a-long-random-string-per-environment>

# ─── Auth secrets — DIFFERENT per environment ─────────────────────────
# Generate fresh JWT keys for stage and again for prod. See contabo-setup
# runbook §Step 7 for the openssl commands. Base64-encode the PEMs.
JWT_PRIVATE_KEY=<base64-of-the-PEM>
JWT_PUBLIC_KEY=<base64-of-the-PEM>
REFRESH_TOKEN_SECRET=<32-byte-random-base64>

# Optional tuning (defaults in the compose file are sane for stage).
# ACCESS_TOKEN_TTL_MIN=15
# REFRESH_TOKEN_TTL_DAYS=7
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100
# AUTH_RATE_LIMIT_MAX=10

# ─── SMTP (hello@perxli.com via DirectAdmin) ─────────────────────────
MAIL_DRIVER=smtp
SMTP_HOST=mail.perxli.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hello@perxli.com
SMTP_PASSWORD=<from-DirectAdmin>
MAIL_FROM=hello@perxli.com
MAIL_FROM_NAME=Perxli

# ─── Google OAuth ────────────────────────────────────────────────────
# Same client ID baked into the frontend bundle at build time. Public —
# safe to set here.
GOOGLE_CLIENT_ID=<copy-from-google-cloud-console>

# ─── Misc ────────────────────────────────────────────────────────────
LOG_LEVEL=info
